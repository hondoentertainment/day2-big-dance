# https://the-odds-api.com/
ODDS_API_KEY=

# Optional: America/New_York for tournament day
TARGET_DATE=2026-03-20
TIMEZONE=America/New_York

# API caching & prod
# GET /api/picks serves memory/disk cache; live refresh = POST /api/picks/refresh
PICKS_CACHE_TTL_SECONDS=180
# Minimum seconds between live Odds API refreshes (429 if faster)
ODDS_MIN_INTERVAL_SECONDS=45
# If set, browser must send matching X-Refresh-Secret header on refresh
REFRESH_SECRET=
# Comma-separated origins for CORS, or * (credentials disabled)
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
# 1 = never call Odds API; serve data/last_picks.json only
SERVE_CACHED_ONLY=0
